# Copy this file to .env and fill in the real values.
# NEVER commit the real .env.

# ===== LARK APP (Developer Console → your app → Credentials) =====
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=your_app_secret_here
LARK_VERIFICATION_TOKEN=your_verification_token_here
LARK_ENCRYPT_KEY=
LARK_DOMAIN=https://open.larksuite.com

# ===== CENTRAL GROUP (chat the bot reports into) =====
CENTRAL_GROUP_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== SERVER (public HTTPS base URL of this bot) =====
SERVER_BASE_URL=https://your-domain.example.com

# ===== GOOGLE SHEETS (OAuth 2.0 installed-app flow) =====
# OAuth client secrets file downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=./inactiveness_client.json
# Cached authorized-user token. Created by the first local run's browser
# consent — COPY this file to the server (headless servers can't open the
# consent browser).
GOOGLE_TOKEN_PATH=./google_token.json
SPREADSHEET_ID=your_google_sheet_id_here

# ===== THRESHOLDS (days) =====
INACTIVITY_THRESHOLD_DAYS=120
WARN_THRESHOLD_DAYS=90
NEAR_INACTIVE_DAYS=15
REALERT_COOLDOWN_DAYS=7
WEEKLY_INACTIVE_DAYS=30

# ===== DAILY DIGEST =====
DAILY_REPORT_TZ=Asia/Bangkok
DAILY_REPORT_HOUR=12
# Afternoon digest hour; also the weekly report hour. No afternoon digest on
# Friday — the weekly report goes out then instead.
DAILY_REPORT_HOUR_PM=17
NOTIFY_ON_NEW_GROUP=false

# ===== AUDIT ACTIVITY (which audit events count as "group is alive") =====
AUDIT_ACTIVITY_ENABLED=true
AUDIT_ACTIVITY_LOOKBACK_DAYS=1
AUDIT_ACTIVITY_EVENTS=im_chat_uploadfile,im_send_link,im_chat_editimage,im_chat_withdraw,im_addtochat,im_deletefromchat,im_add_chatadmin,im_delete_chatadmin,im_forward_chatadmin,im_admin_no_restrict_ctrl,im_join_chat,im_quit_chat,im_chat_pin_create,im_chat_pin_update,im_chat_pin_update_permission,im_chat_pin_delete,im_chat_pin_stick,im_chat_pin_unstick,im_export_chat_chatter,im_forward_file,im_savetospace,im_chat_previewfile,im_copy_image,im_open_link,im_download,im_download_file,im_download_image,im_download_video,im_load_file_to_local,im_snaphot,im_screencap,im_ocr,im_read_doc,im_download_doc,im_open_with_3rdApp

# ===== LOGS =====
LOG_DIR=./logs
