ive."}, {"id": "lark_cards_new_group_gap_card", "label": "new_group_gap_card", "file_type": "code", "source_file": "docs/bot_message_plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "lark_webhook_handle_new_group", "label": "_handle_new_group", "file_type": "code", "source_file": "docs/bot_message_plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "lark_cards_inactive_alert_card", "label": "inactive_alert_card", "file_type": "code", "source_file": "docs/bot_message_plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "checker_alert", "label": "checker._alert", "file_type": "code", "source_file": "docs/bot_message_plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "lark_cards_weekly_summary_card", "label": "weekly_summary_card", "file_type": "code", "source_file": "docs/bot_message_plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "weekly_summary_run_weekly_summary", "label": "run_weekly_summary", "file_type": "code", "source_file": "docs/bot_message_plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "checker_ping_reauth", "label": "checker._ping_reauth", "file_type": "code", "source_file": "docs/bot_message_plan.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_bot_message_plan_bot_message_plan", "target": "docs_bot_message_plan_new_group_coverage_gap", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/bot_message_plan.md", "source_location": null, "weight": 1.0}, {"source": "docs_bot_message_plan_bot_message_plan", "ta